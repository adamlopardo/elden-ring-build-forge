# ---------------------------------------------------------------------------
# ELDEN RING BUILD FORGE — environment variables
# ---------------------------------------------------------------------------
# Your Anthropic API key. Used ONLY on the server in app/api/chat/route.ts.
# Never expose this in client code. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the model used by the AI route planner.
# Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6
